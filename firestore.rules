rules_version = '2';

// ============================================================================
//  Règles de sécurité Firestore — Luach Mivchanim
// ----------------------------------------------------------------------------
//  ARCHITECTURE : toutes les lectures/écritures de données passent par le
//  backend Python (Streamlit + firebase-admin / Admin SDK). L'Admin SDK
//  s'exécute avec des privilèges de service et CONTOURNE ces règles. Aucun
//  client (navigateur, app React d'auth) n'accède directement à Firestore :
//  le composant front ne fait que de l'authentification Firebase Auth.
//
//  Posture : on REFUSE donc tout accès client direct. C'est la configuration
//  la plus sûre et elle n'impacte pas le backend (qui bypasse ces règles).
//
//  ⚠️ Si un jour du code CLIENT lit/écrit Firestore directement, il faudra
//  ajouter ici des règles explicites basées sur `request.auth` (ex. comparer
//  request.auth.token.email à owner_email de l'école ou au doc
//  schools/{id}/permissions/{email}). Ne JAMAIS revenir à un `allow ... if true`
//  ni à une règle "test mode" expirante.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
